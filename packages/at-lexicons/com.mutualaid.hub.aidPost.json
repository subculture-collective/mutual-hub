{
    "lexicon": 1,
    "id": "com.mutualaid.hub.aidPost",
    "description": "Mutual Hub aid request record schema v1",
    "defs": {
        "main": {
            "type": "record",
            "key": "tid",
            "record": {
                "type": "object",
                "required": [
                    "id",
                    "title",
                    "description",
                    "category",
                    "urgency",
                    "status",
                    "createdAt",
                    "updatedAt",
                    "accessibilityTags"
                ],
                "properties": {
                    "id": { "type": "string", "maxLength": 128 },
                    "title": { "type": "string", "maxLength": 180 },
                    "description": { "type": "string", "maxLength": 4000 },
                    "category": {
                        "type": "string",
                        "knownValues": [
                            "food",
                            "shelter",
                            "medical",
                            "transport",
                            "childcare",
                            "supplies",
                            "other"
                        ]
                    },
                    "urgency": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 5
                    },
                    "status": {
                        "type": "string",
                        "knownValues": ["open", "in_progress", "closed"]
                    },
                    "createdAt": { "type": "string", "format": "datetime" },
                    "updatedAt": { "type": "string", "format": "datetime" },
                    "location": {
                        "type": "object",
                        "required": ["lat", "lng", "precisionMeters"],
                        "properties": {
                            "lat": {
                                "type": "float",
                                "minimum": -90,
                                "maximum": 90
                            },
                            "lng": {
                                "type": "float",
                                "minimum": -180,
                                "maximum": 180
                            },
                            "precisionMeters": {
                                "type": "integer",
                                "minimum": 100,
                                "maximum": 5000
                            },
                            "areaLabel": { "type": "string", "maxLength": 200 }
                        }
                    },
                    "accessibilityTags": {
                        "type": "array",
                        "items": { "type": "string", "maxLength": 64 },
                        "maxLength": 20
                    }
                }
            }
        }
    }
}
