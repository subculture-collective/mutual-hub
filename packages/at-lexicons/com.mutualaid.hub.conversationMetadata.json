{
    "lexicon": 1,
    "id": "com.mutualaid.hub.conversationMetadata",
    "description": "Mutual Hub conversation metadata schema v1",
    "defs": {
        "main": {
            "type": "record",
            "key": "tid",
            "record": {
                "type": "object",
                "required": [
                    "id",
                    "postUri",
                    "requesterDid",
                    "recipientDid",
                    "state",
                    "createdAt",
                    "updatedAt"
                ],
                "properties": {
                    "id": { "type": "string", "maxLength": 128 },
                    "postUri": { "type": "string", "format": "at-uri" },
                    "requesterDid": { "type": "string", "format": "did" },
                    "recipientDid": { "type": "string", "format": "did" },
                    "state": {
                        "type": "string",
                        "knownValues": [
                            "open",
                            "handoff_suggested",
                            "resolved",
                            "blocked"
                        ]
                    },
                    "requestContext": {
                        "type": "object",
                        "required": [
                            "source",
                            "postTitle",
                            "category",
                            "urgency"
                        ],
                        "properties": {
                            "source": {
                                "type": "string",
                                "knownValues": [
                                    "map_detail",
                                    "feed_card",
                                    "post_detail"
                                ]
                            },
                            "postTitle": { "type": "string", "maxLength": 180 },
                            "category": {
                                "type": "string",
                                "knownValues": [
                                    "food",
                                    "shelter",
                                    "medical",
                                    "transport",
                                    "childcare",
                                    "supplies",
                                    "other"
                                ]
                            },
                            "urgency": {
                                "type": "integer",
                                "minimum": 1,
                                "maximum": 5
                            },
                            "areaLabel": { "type": "string", "maxLength": 200 }
                        }
                    },
                    "routingDestinationType": {
                        "type": "string",
                        "knownValues": [
                            "post_author",
                            "volunteer_pool",
                            "resource_directory",
                            "manual_review"
                        ]
                    },
                    "routingDestinationId": {
                        "type": "string",
                        "maxLength": 256
                    },
                    "routingRationale": { "type": "string", "maxLength": 2000 },
                    "transportMode": {
                        "type": "string",
                        "knownValues": ["atproto_native", "fallback_notice"]
                    },
                    "fallbackReason": {
                        "type": "string",
                        "knownValues": [
                            "recipient_unsupported",
                            "recipient_opt_out",
                            "recipient_unreachable"
                        ]
                    },
                    "fallbackNotice": { "type": "string", "maxLength": 500 },
                    "createdAt": { "type": "string", "format": "datetime" },
                    "updatedAt": { "type": "string", "format": "datetime" }
                }
            }
        }
    }
}
