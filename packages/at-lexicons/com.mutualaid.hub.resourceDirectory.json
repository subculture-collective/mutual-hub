{
    "lexicon": 1,
    "id": "com.mutualaid.hub.resourceDirectory",
    "description": "Mutual Hub resource directory schema v1",
    "defs": {
        "main": {
            "type": "record",
            "key": "tid",
            "record": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "type",
                    "location",
                    "createdAt",
                    "updatedAt"
                ],
                "properties": {
                    "id": { "type": "string", "maxLength": 128 },
                    "name": { "type": "string", "maxLength": 180 },
                    "type": {
                        "type": "string",
                        "knownValues": [
                            "shelter",
                            "clinic",
                            "food_bank",
                            "support_service"
                        ]
                    },
                    "location": {
                        "type": "object",
                        "required": ["lat", "lng", "precisionMeters"],
                        "properties": {
                            "lat": {
                                "type": "float",
                                "minimum": -90,
                                "maximum": 90
                            },
                            "lng": {
                                "type": "float",
                                "minimum": -180,
                                "maximum": 180
                            },
                            "precisionMeters": {
                                "type": "integer",
                                "minimum": 100,
                                "maximum": 5000
                            },
                            "areaLabel": { "type": "string", "maxLength": 200 }
                        }
                    },
                    "openHours": { "type": "string", "maxLength": 500 },
                    "eligibilityNotes": { "type": "string", "maxLength": 1000 },
                    "createdAt": { "type": "string", "format": "datetime" },
                    "updatedAt": { "type": "string", "format": "datetime" }
                }
            }
        }
    }
}
