{
    "lexicon": 1,
    "id": "app.mutualhub.moderation.report",
    "revision": "1.0.0",
    "description": "Moderation report record for posts/chats/resources.",
    "defs": {
        "main": {
            "type": "record",
            "key": "tid",
            "record": {
                "type": "object",
                "required": [
                    "$type",
                    "version",
                    "subjectUri",
                    "reporterDid",
                    "reason",
                    "createdAt"
                ],
                "properties": {
                    "$type": {
                        "type": "string",
                        "const": "app.mutualhub.moderation.report"
                    },
                    "version": { "type": "string", "const": "1.0.0" },
                    "subjectUri": { "type": "string" },
                    "reporterDid": { "type": "string" },
                    "reason": { "type": "string" },
                    "details": { "type": "string", "maxLength": 1000 },
                    "createdAt": { "type": "string", "format": "datetime" }
                }
            }
        }
    }
}
