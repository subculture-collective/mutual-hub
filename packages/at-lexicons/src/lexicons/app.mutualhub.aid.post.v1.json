          "title": { "type": "string", "maxLength": 140 },
          "description": { "type": "string", "maxLength": 5000 },
          "category": { "type": "string" },
          "urgency": { "type": "string" },
          "status": { "type": "string" },
          "location": { "type": "object" },
          "createdAt": { "type": "string", "format": "datetime" },
