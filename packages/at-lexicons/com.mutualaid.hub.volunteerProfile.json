{
  "lexicon": 1,
  "id": "com.mutualaid.hub.volunteerProfile",
  "description": "Mutual Hub volunteer profile schema v1",
  "defs": {
    "main": {
      "type": "record",
      "key": "literal:self",
      "record": {
        "type": "object",
        "required": [
          "did",
          "displayName",
          "skills",
          "availability",
          "verified",
          "preferredAidCategories",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "did": { "type": "string", "format": "did" },
          "displayName": { "type": "string", "maxLength": 120 },
          "skills": {
            "type": "array",
            "items": { "type": "string", "maxLength": 64 },
            "maxLength": 50
          },
          "availability": {
            "type": "array",
            "items": { "type": "string", "maxLength": 64 },
            "maxLength": 30
          },
          "verified": { "type": "boolean" },
          "preferredAidCategories": {
            "type": "array",
            "items": { "type": "string", "maxLength": 64 },
            "maxLength": 20
          },
          "createdAt": { "type": "string", "format": "datetime" },
          "updatedAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
