{
  "lexicon": 1,
  "id": "com.mutualaid.hub.moderationReport",
  "description": "Mutual Hub moderation/report schema v1",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["id", "targetUri", "reason", "reporterDid", "createdAt"],
        "properties": {
          "id": { "type": "string", "maxLength": 128 },
          "targetUri": { "type": "string", "format": "at-uri" },
          "reason": {
            "type": "string",
            "knownValues": ["spam", "harassment", "fraud", "unsafe_content", "other"]
          },
          "reporterDid": { "type": "string", "format": "did" },
          "details": { "type": "string", "maxLength": 2000 },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
