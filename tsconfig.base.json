{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "noEmitOnError": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@mutual-hub/at-lexicons": ["packages/at-lexicons/src/index.ts"],
      "@mutual-hub/at-protocol": ["packages/at-protocol/src/index.ts"],
      "@mutual-hub/config": ["packages/config/src/index.ts"],
      "@mutual-hub/shared": ["packages/shared/src/index.ts"]
    }
  }
}
